}
nav ul{
display:flex;
list-style:none;
gap:25px;
}
nav a{
color:white;
text-decoration:none;
font-weight:600;
}

/* HERO */
.hero{
height:100vh;
background:
linear-gradient(rgba(0,0,0,.45),rgba(0,0,0,.55)),
url("https://images.unsplash.com/photo-1500937386664-56d1dfef3854?auto=format&fit=crop&w=1920&q=80");
