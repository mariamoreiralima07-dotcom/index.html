display:flex;
align-items:center;
justify-content:center;
text-align:center;
padding:20px;
color:white;
}
.hero h1{
font-size:3rem;
margin-bottom:20px;
text-shadow:2px 2px 8px black;
}
.hero p{
font-size:1.3rem;
max-width:900px;
margin:auto;
text-shadow:1px 1px 6px black;
}
.btn{
display:inline-block;
margin-top:30px;
padding:15px 35px;
background:var(--verde);
color:white;
text-decoration:none;
border-radius:50px;
font-weight:700;
transition:.4s;
}
.btn:hover{
background:var(--verde2);
transform:translateY(-5px);
}

/* SEÇÕES */
section{
padding:100px 10%;
}
.titulo{
text-align:center;
font-size:2.5rem;
margin-bottom:30px;
color:var(--marrom1);
}
.cards{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
gap:25px;
}
.card{
background:white;
padding:30px;
border-radius:20px;
box-shadow:0 10px 25px rgba(0,0,0,.1);
transition:.4s;
}
.card:hover{
transform:translateY(-10px);
}
.card h3{
color:var(--verde);
margin-bottom:15px;
}

/* GALERIA */
.galeria{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
gap:20px;
}
.galeria img{
width:100%;
height:250px;
object-fit:cover;
border-radius:20px;
transition:.4s;
}
.galeria img:hover{
transform:scale(1.05);
}

/* EMOJIS */
.area-curtidas{
text-align:center;
background:white;
padding:40px;
border-radius:20px;
}
.emojis{
display:flex;
justify-content:center;
gap:20px;
flex-wrap:wrap;
margin-top:20px;
}
.emoji{
font-size:3rem;
cursor:pointer;
transition:.3s;
}
.emoji:hover{
transform:scale(1.3);
}
.contador{
margin-top:20px;
font-size:1.4rem;
font-weight:bold;
color:var(--marrom1);
}

/* AUTORA */
.autora{
background:var(--marrom1);
color:white;
text-align:center;
padding:60px;
border-radius:20px;
}
.autora h2{
font-size:2.2rem;
margin-bottom:10px;
}

/* FOOTER */
footer{
background:#2b1b17;
color:white;
text-align:center;
padding:40px;
}

@media(max-width:768px){
.hero h1{
font-size:2rem;
}
body{
font-size:18px;
}
}
</style>
</head>
